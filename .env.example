# ═══════════════════════════════════════════════════════════════════
#  NomadNest Taiwan — 環境變數範本
#  複製此檔並命名為 .env，填入實際值後即可啟動專案。
#  ⚠️  .env 已加入 .gitignore，請勿將真實金鑰提交到版本控制！
# ═══════════════════════════════════════════════════════════════════

# ─── 資料庫 ─────────────────────────────────────────────────────────
# 開發：SQLite（相對路徑，以 prisma/dev.db 為準）
# 正式：PostgreSQL — postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL="file:./dev.db"

# ─── JWT 認證金鑰 ────────────────────────────────────────────────────
# ⚠️  強度要求：至少 32 個隨機字元。生產環境請使用 64+ 字元。
# 生成方式：openssl rand -hex 32
# 注意：若金鑰太弱（< 32 字元），伺服器啟動時會印出警告。
JWT_SECRET="REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS"

# ─── 應用程式 URL ─────────────────────────────────────────────────────
# 開發：http://localhost:3001（依 package.json 的 -p 3001 設定）
# 正式：https://nomadnest.tw
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_BASE_URL="http://localhost:3001"

# ─── Supabase Storage（圖片雲端上傳）───────────────────────────────
# 前往 https://supabase.com → 你的專案 → Settings → API 取得
#
# Project URL（公開，可放 NEXT_PUBLIC_）
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
#
# Service Role Key（⚠️  伺服器端專用，絕對不要暴露給前端或提交到 Git！）
# 取得路徑：Supabase Dashboard → Settings → API → service_role（JWT 格式，以 eyJ 開頭）
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Email 通知（可選）──────────────────────────────────────────────
# 未設定時，寄信動作僅輸出 console.log（開發模式不影響核心功能）
#
# Gmail 設定（需先在 Google 帳號開啟「應用程式密碼」）：
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx   ← 16 碼應用程式密碼（非登入密碼）
#   SMTP_FROM=NomadNest <your@gmail.com>
#
# Resend（推薦正式環境使用，https://resend.com）：
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxx       ← Resend API Key
#   SMTP_FROM=NomadNest Taiwan <no-reply@nomadnest.tw>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NomadNest Taiwan <no-reply@nomadnest.tw>"

# ─── Cron Job 保護金鑰 ───────────────────────────────────────────────
# 用於保護 /api/cron/* 端點，防止未授權調用。
# ⚠️  生產環境請務必使用高強度隨機字串！
# 生成方式：openssl rand -hex 32
# 調用方式：Authorization: Bearer YOUR_CRON_SECRET
CRON_SECRET="REPLACE_WITH_STRONG_RANDOM_STRING_openssl_rand_hex_32"

# ─── Web Push / VAPID（瀏覽器推播通知）──────────────────────────────
# 若不需要推播通知功能，可留空（功能將自動停用）。
# 生成方式：
#   npm install -g web-push
#   web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BExamplePublicKey..."
VAPID_PRIVATE_KEY="ExamplePrivateKey..."
VAPID_SUBJECT="mailto:support@nomadnest.tw"
